{
  "manifest_version": 3,
  "name": "GHL Message Catcher",
  "version": "1.0",
  "description": "Catch outbound messages from GoHighLevel",
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["scripting"],
  "host_permissions": [
    "*://*.gohighlevel.com/*",
    "https://nontautological-proauthor-ramiro.ngrok-free.dev/*"
  ],
  "content_scripts": [
    {
      "matches": ["*://*.gohighlevel.com/*"],
      "js": ["Api.js", "content.js"]
    }
  ]
}